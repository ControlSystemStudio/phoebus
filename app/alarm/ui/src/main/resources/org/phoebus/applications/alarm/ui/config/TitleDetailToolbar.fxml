<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<Pane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.phoebus.applications.alarm.ui.config.TitleDetailToolbarController">
            <children>
    <VBox spacing="5">
            <children>
                <!-- Add button -->
                <Button fx:id="addButton" mnemonicParsing="false" onAction="#handleAdd">
                    <graphic>
                        <ImageView>
                            <image>
                                <Image url="@/icons/add.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="%tooltipAddTableItem" />
                    </tooltip>
                </Button>

                <!-- Edit button -->
                <Button fx:id="editButton" disable="true" mnemonicParsing="false" onAction="#handleEdit">
                    <graphic>
                        <ImageView>
                            <image>
                                <Image url="@/icons/edit.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="%tooltipMoveEditDetail" />
                    </tooltip>
                </Button>

                <!-- Move-up button -->
                <Button fx:id="upButton" disable="true" mnemonicParsing="false" onAction="#handleUp">
                    <graphic>
                        <ImageView>
                            <image>
                                <Image url="@/icons/up.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="%tooltipMoveTableItemUp" />
                    </tooltip>
                </Button>

                <!-- Move-down button -->
                <Button fx:id="downButton" disable="true" mnemonicParsing="false" onAction="#handleDown">
                    <graphic>
                        <ImageView>
                            <image>
                                <Image url="@/icons/down.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="%tooltipMoveTableItemDown" />
                    </tooltip>
                </Button>

                <!-- Delete button -->
                <Button fx:id="deleteButton" disable="true" mnemonicParsing="false" onAction="#handleDelete">
                    <graphic>
                        <ImageView>
                            <image>
                                <Image url="@/icons/delete.png" />
                            </image>
                        </ImageView>
                    </graphic>
                    <tooltip>
                        <Tooltip text="%tooltipDeleteSelectedItems" />
                    </tooltip>
                </Button>
            </children>
            <padding>
                <Insets left="5.0" />
            </padding>
        </VBox>
    </children>
</Pane>
