<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.phoebus.applications.alarm.ui.config.DateTimePicker?>

<ScrollPane fx:id="scroll" fitToWidth="true"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.phoebus.applications.alarm.ui.config.ItemConfigDialogController">

    <GridPane fx:id="layout" hgap="5" vgap="5">
        <padding>
            <Insets top="5" right="5" bottom="5" left="5"/>
        </padding>

        <columnConstraints>
            <!-- Column 0: fixed 190 px label column -->
            <ColumnConstraints minWidth="190" prefWidth="190" maxWidth="190"/>
            <!-- Column 1: grows to fill available width -->
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <!-- ═══════════════════════════════════════════
             Row 0 – Path  (read-only)
             ═══════════════════════════════════════════ -->
        <Label text="%path" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="path" editable="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                   GridPane.hgrow="ALWAYS"/>

        <!-- ═══════════════════════════════════════════
             Leaf-only section  (rows 1-6)
             Visibility controlled by the controller.
             ═══════════════════════════════════════════ -->

        <!-- Row 1 – Description -->
        <Label fx:id="descriptionLabel" text="%description"
               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="description"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   GridPane.hgrow="ALWAYS">
            <tooltip>
                <Tooltip text="%descriptionTooltip"/>
            </tooltip>
        </TextField>

        <!-- Row 2 – Behavior checkboxes -->
        <Label fx:id="behaviorLabel" text="%behavior"
               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <HBox fx:id="behaviorBox" spacing="10" alignment="CENTER_LEFT"
              GridPane.columnIndex="1" GridPane.rowIndex="2">
            <CheckBox fx:id="enabled" text="%enabled">
                <tooltip>
                    <Tooltip text="%behaviorTooltip"/>
                </tooltip>
            </CheckBox>
            <CheckBox fx:id="latching" text="%latch">
                <tooltip>
                    <Tooltip text="%latchTooltip"/>
                </tooltip>
            </CheckBox>
            <CheckBox fx:id="annunciating" text="%annunciate">
                <tooltip>
                    <Tooltip text="%annunciateTooltip"/>
                </tooltip>
            </CheckBox>
        </HBox>

        <!-- Row 3 – Disable until (DateTimePicker + relative ComboBox) -->
        <Label fx:id="disableUntilLabel" text="%disableUntil"
               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <!--
            DateTimePicker is a custom control; it is created/injected by the controller.
            The HBox here acts as the container that the controller populates.
        -->
        <HBox fx:id="untilBox" spacing="10" alignment="CENTER"
              GridPane.columnIndex="1" GridPane.rowIndex="3">

            <DateTimePicker fx:id="enabledDatePicker" prefWidth="280" prefHeight="25">
                <tooltip>
                    <Tooltip text="%dateTimePickerTooltip"/>
                </tooltip>
            </DateTimePicker>
            <ComboBox fx:id="relativeDate" prefWidth="200" prefHeight="25"
                      HBox.hgrow="ALWAYS">
                <tooltip>
                    <Tooltip text="%relativeDateTooltip"/>
                </tooltip>
            </ComboBox>
        </HBox>

        <!-- Row 4 – Alarm Delay -->
        <Label fx:id="delayLabel" text="%alarmDelay"
               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <!--
            Spinner value factory (0..MAX_VALUE) is set in the controller.
            The dynamic tooltip text is also set in the controller.
        -->
        <Spinner fx:id="delay" editable="true" prefWidth="80"
                 GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <!-- Row 5 – Alarm Count -->
        <Label fx:id="countLabel" text="%alarmCount"
               GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <Spinner fx:id="count" editable="true" prefWidth="80"
                 GridPane.columnIndex="1" GridPane.rowIndex="5">
            <tooltip>
                <Tooltip text="%alarmCountTooltip"/>
            </tooltip>
        </Spinner>

        <!-- Row 6 – Enabling Filter -->
        <Label fx:id="filterLabel" text="%enablingFilter"
               GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="filter"
                   GridPane.columnIndex="1" GridPane.rowIndex="6"
                   GridPane.hgrow="ALWAYS">
            <tooltip>
                <Tooltip text="%enablingFilterTooltip"/>
            </tooltip>
        </TextField>

        <!-- ═══════════════════════════════════════════
             Shared section  (always visible)
             ═══════════════════════════════════════════ -->

        <!-- Row 7 – Guidance label (spans 2 columns) -->
        <Label text="%guidance"
               GridPane.columnIndex="0" GridPane.rowIndex="7"
               GridPane.columnSpan="2"/>

        <!-- Row 8 – Guidance table placeholder (spans 2 columns) -->
        <!--
            TitleDetailTable cannot be used directly in FXML without a custom builder.
            The controller creates it and places it inside this StackPane.
        -->
        <StackPane fx:id="guidancePlaceholder" prefHeight="100"
                   GridPane.columnIndex="0" GridPane.rowIndex="8"
                   GridPane.columnSpan="2" GridPane.hgrow="ALWAYS"/>

        <!-- Row 9 – Displays label -->
        <Label text="%displays"
               GridPane.columnIndex="0" GridPane.rowIndex="9"
               GridPane.columnSpan="2"/>

        <!-- Row 10 – Displays table placeholder -->
        <StackPane fx:id="displaysPlaceholder" prefHeight="100"
                   GridPane.columnIndex="0" GridPane.rowIndex="10"
                   GridPane.columnSpan="2" GridPane.hgrow="ALWAYS"/>

        <!-- Row 11 – Commands label -->
        <Label text="%commands"
               GridPane.columnIndex="0" GridPane.rowIndex="11"
               GridPane.columnSpan="2"/>

        <!-- Row 12 – Commands table placeholder -->
        <StackPane fx:id="commandsPlaceholder" prefHeight="100"
                   GridPane.columnIndex="0" GridPane.rowIndex="12"
                   GridPane.columnSpan="2" GridPane.hgrow="ALWAYS"/>

        <!-- Row 13 – Automated Actions label -->
        <Label text="%automatedActions"
               GridPane.columnIndex="0" GridPane.rowIndex="13"
               GridPane.columnSpan="2"/>

        <!-- Row 14 – Automated Actions table placeholder -->
        <StackPane fx:id="actionsPlaceholder" prefHeight="100"
                   GridPane.columnIndex="0" GridPane.rowIndex="14"
                   GridPane.columnSpan="2" GridPane.hgrow="ALWAYS"/>

    </GridPane>
</ScrollPane>
